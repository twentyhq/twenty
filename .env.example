# ==============================================================================
# Twenty CRM — Szablon zmiennych środowiskowych (.env.example)
# ==============================================================================
# INSTRUKCJA:
# 1. Skopiuj ten plik: cp .env.example .env
# 2. Uzupełnij wartości poniżej
# 3. NIGDY nie commituj pliku .env z prawdziwymi hasłami!
# ==============================================================================

# --- Wersja Twenty CRM ---
TAG=latest

# --- Baza danych PostgreSQL ---
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=WSTAW_SILNE_HASLO_BEZ_ZNAKOW_SPECJALNYCH
PG_DATABASE_HOST=db
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=default

# --- Redis (cache) ---
REDIS_URL=redis://redis:6379

# --- Adres aplikacji ---
SERVER_URL=https://toniedevcrm.salesmasters.pl

# --- Sekret aplikacji ---
# Wygeneruj komendą: openssl rand -base64 32
APP_SECRET=WSTAW_WYGENEROWANY_SEKRET

# --- Przechowywanie plików ---
STORAGE_TYPE=local

# --- S3 Storage (odkomentuj jeśli STORAGE_TYPE=s3) ---
# STORAGE_S3_REGION=eu-central-1
# STORAGE_S3_NAME=nazwa-bucketa
# STORAGE_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com

# --- Migracje bazy (nie zmieniaj bez potrzeby) ---
# DISABLE_DB_MIGRATIONS=false
# DISABLE_CRON_JOBS_REGISTRATION=false
