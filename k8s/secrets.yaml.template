# Kubernetes Secrets for Twenty CRM
# IMPORTANT: This is a template. Copy to secrets.yaml and fill in your actual values.
# DO NOT commit secrets.yaml to git!

apiVersion: v1
kind: Secret
metadata:
  name: twenty-secrets
  namespace: twenty-crm
type: Opaque
stringData:
  # Database Connection
  # Get this from OVHcloud Managed PostgreSQL dashboard
  PG_DATABASE_URL: "postgresql://username:password@postgresql-xxxx.priv.cloud.ovh.net:5432/twentycrm"

  # Redis Connection
  # Get this from OVHcloud Managed Valkey dashboard
  REDIS_URL: "rediss://default:password@valkey-xxxx.priv.cloud.ovh.net:6379"

  # Application Secret
  # Generate with: openssl rand -hex 32
  APP_SECRET: "REPLACE_WITH_RANDOM_64_CHAR_STRING"

  # Object Storage (S3) Credentials
  # Get these from OVHcloud Object Storage dashboard
  STORAGE_S3_ACCESS_KEY_ID: "REPLACE_WITH_OVH_S3_ACCESS_KEY"
  STORAGE_S3_SECRET_ACCESS_KEY: "REPLACE_WITH_OVH_S3_SECRET_KEY"

  # Google OAuth (Optional - if using Google auth)
  AUTH_GOOGLE_CLIENT_SECRET: ""

  # Sentry DSN (Optional - for error tracking)
  SENTRY_DSN: ""
  SENTRY_FRONT_DSN: ""
