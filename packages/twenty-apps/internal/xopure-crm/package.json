{
  "name": "xopure-crm",
  "version": "0.1.2",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "^24.5.0",
    "npm": "please-use-yarn",
    "yarn": ">=4.0.2"
  },
  "keywords": [
    "twenty-app",
    "xopure",
    "crm"
  ],
  "packageManager": "yarn@4.9.2",
  "scripts": {
    "twenty": "twenty",
    "app-factory": "cd ../../../.. && yarn tsx packages/twenty-apps/internal/xopure-crm/src/app-factory/cli/orchestrator-cli.ts",
    "app-factory:pip3r": "cd ../../../.. && yarn tsx packages/twenty-apps/internal/xopure-crm/src/app-factory/plugin/pip3r-plugin.ts",
    "lint": "oxlint -c .oxlintrc.json .",
    "lint:fix": "oxlint --fix -c .oxlintrc.json .",
    "test": "vitest run -c vitest.unit.config.ts",
    "test:watch": "vitest -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.config.ts --passWithNoTests",
    "test:integration:watch": "vitest -c vitest.config.ts --passWithNoTests"
  },
  "dependencies": {
    "twenty-client-sdk": "2.3.0",
    "twenty-sdk": "2.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/react": "^19.0.0",
    "oxlint": "^0.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^3.1.1"
  }
}
