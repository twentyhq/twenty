{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "src/*": ["./src/*"],
      "twenty-sdk": ["../../../twenty-sdk/src/sdk"]
    }
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "dist", ".twenty"]
}
