{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": "../..",
    "sourceMap": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "resolveJsonModule": true,
    "target": "ES2020",
    "jsx": "react-jsx",
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["node", "jest"],
    "outDir": "../../.cache/tsc",
    "paths": {
      "@ui/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"],
      "@styles/*": ["./src/styles/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    ".storybook/*.ts",
    ".storybook/*.tsx",
    "jest.config.mjs",
    "setupTests.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "tmp"]
}
