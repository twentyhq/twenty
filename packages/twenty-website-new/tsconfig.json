// This tsconfig is intentionally standalone — it does NOT extend
// `tsconfig.base.json` from the monorepo root. See ARCHITECTURE.md §13.
//
// Why: the base config targets the rest of the monorepo (NestJS server,
// React libraries, NX-built packages). Its choices conflict with what
// Next.js + the Next compiler / `tsgo` need here:
//
//   | Setting             | base               | here (required)              |
//   | ------------------- | ------------------ | ---------------------------- |
//   | `moduleResolution`  | `node`             | `bundler` (Next 13+)         |
//   | `target`            | `es2018`           | `es2020`                     |
//   | `jsx`               | (unset)            | `react-jsx`                  |
//   | `strict`            | (unset)            | `true`                       |
//   | `paths`             | (unset)            | `{ "@/*": ["./src/*"] }`     |
//   | `incremental`       | (unset)            | `true` (Next dev cache)      |
//   | `plugins`           | (unset)            | `[{ "name": "next" }]`       |
//
// Extending the base would require overriding nearly every field, at
// which point the inheritance buys nothing. When the rest of the
// monorepo migrates off the legacy base config (or to per-app configs
// matching this one), revisit.
{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
