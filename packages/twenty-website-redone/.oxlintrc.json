{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "plugins": ["react", "typescript", "oxc", "unicorn"],
  "rules": {
    "react/react-in-jsx-scope": "off",
    "typescript/no-explicit-any": "error",
    "typescript/consistent-type-definitions": ["error", "type"]
  }
}
