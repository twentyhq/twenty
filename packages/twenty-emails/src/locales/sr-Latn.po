#. js-lingui-explicit-id
#: src/emails/password-update-notify.email.tsx
msgid "Password updated"
msgstr "Šifra je osvežena"

#. js-lingui-explicit-id
#: src/emails/password-update-notify.email.tsx
msgid "This is a confirmation that password for your account ({email}) was successfully changed on {formattedDate}."
msgstr "Ovo je potvrda da je šifra vašeg naloga ({email}) uspešno promenjena na {formattedDate}."

#. js-lingui-explicit-id
#: src/emails/password-update-notify.email.tsx
msgid "If you did not initiate this change, please contact your workspace owner immediately."
msgstr "Ako ovu promenu niste pokrenuli vi, molimo vas da odmah kontaktirate vlasnika vašeg radnog prostora."

#. js-lingui-explicit-id
#: src/emails/password-update-notify.email.tsx
msgid "Connect to Twenty"
msgstr "Povežite se sa Twenty"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "Reset your password 🗝"
msgstr "Resetujte vašu šifru 🗝"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "Set your password 🗝"
msgstr "Podesite svoju lozinku 🗝"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "Reset"
msgstr "Resetuj"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "Set"
msgstr "Podesiti"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "This link is only valid for the next {duration}. If the link does not work, you can use the login verification link directly:"
msgstr "Ovaj link je validan samo sledećih {duration}. Ako link ne funkcioniše, moći ćete direktno koristiti link za verifikaciju prijave:"

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "Deleted Workspace"
msgstr "Izbrisan radni prostor"

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "Your workspace <0>{workspaceDisplayName}</0> has been deleted as your subscription expired {daysSinceInactive} days ago."
msgstr "Vaš radni prostor <0>{workspaceDisplayName}</0> je izbrisan pošto je vaša pretplata istekla pre {daysSinceInactive} dana."

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "All data in this workspace has been permanently deleted."
msgstr "Svi podaci u ovom radnom prostoru su trajno izbrisani."

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "If you wish to use Twenty again, you can create a new workspace."
msgstr "Ako želite ponovo koristiti Twenty, možete stvoriti novi radni prostor."

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "Create a new workspace"
msgstr "Kreiraj novi radni prostor"

