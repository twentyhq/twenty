# ===================== Orbitor on Supabase — deployment env =====================
# Copy to a private .env file, fill in real values, then (from the repo root):
#   docker compose -f packages/twenty-docker/docker-compose.supabase.yml --env-file .env build
#   docker compose -f packages/twenty-docker/docker-compose.supabase.yml --env-file .env up -d
# See packages/twenty-docker/SUPABASE_DEPLOY.md for the full guide.

# ---- Database: Supabase SESSION pooler (port 5432 — NOT the 6543 transaction pooler) ----
# Supabase dashboard → Connect → Session pooler. DB name is `postgres`.
PG_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
# Keep (core + workspace) x (server + worker) under the pooler client limit (pool_size, default 15).
PG_POOL_MAX_CONNECTIONS=3
PG_SSL_ALLOW_SELF_SIGNED=true

# ---- App ----
SERVER_URL=https://your-domain.example.com
# Generate each with: openssl rand -base64 32
ENCRYPTION_KEY=replace_me_with_openssl_rand_base64_32
# FALLBACK_ENCRYPTION_KEY=   # set to the previous ENCRYPTION_KEY only during a key rotation
REDIS_URL=redis://redis:6379

# ---- Object storage: Supabase S3-compatible (bucket must already exist) ----
# Supabase dashboard → Storage → S3 connection (endpoint + access keys).
STORAGE_TYPE=s3
STORAGE_S3_NAME=orbitor-files
STORAGE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
STORAGE_S3_REGION=ap-northeast-1
STORAGE_S3_ACCESS_KEY_ID=replace_me
STORAGE_S3_SECRET_ACCESS_KEY=replace_me

# ---- Clean start: no demo/sample records or workflows in new workspaces ----
IS_WORKSPACE_DEMO_DATA_ENABLED=false
