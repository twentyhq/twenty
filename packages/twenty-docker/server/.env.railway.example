# ===================== Orbitor backend env (Railway) =====================
# These go on the Railway "server" service (and most are shared to the
# "worker" service). DEPLOY.md explains where each value comes from.
# Values shown as ${{...}} are Railway "reference variables" — Railway fills
# them in automatically when you add the Postgres and Redis plugins.

# ---- Database: Railway Postgres (added as a plugin in the same project) ----
PG_DATABASE_URL=${{Postgres.DATABASE_URL}}

# ---- Cache/queue: Railway Redis (added as a plugin in the same project) ----
REDIS_URL=${{Redis.REDIS_URL}}

# ---- Secret: signs tokens + encrypts secrets at rest. Generate once:
#      openssl rand -base64 32
APP_SECRET=replace_me_with_openssl_rand_base64_32

# ---- App URLs ----
# The server listens on this port; keep it 3000 and set Railway's target port to 3000.
NODE_PORT=3000
# Public URL of THIS backend (Railway gives it after first deploy), e.g.
#   https://orbitor-server-production.up.railway.app
SERVER_URL=https://REPLACE-with-railway-server-url
# Public URL of the Cloudflare Pages frontend, e.g.
#   https://orbitor.pages.dev
FRONTEND_URL=https://REPLACE-with-cloudflare-pages-url

# ---- File storage: Cloudflare R2 (S3-compatible) ----
STORAGE_TYPE=s3
STORAGE_S3_NAME=orbitor-files
STORAGE_S3_ENDPOINT=https://5aec49dc270dd7fd739f1e8e72f0030d.r2.cloudflarestorage.com
STORAGE_S3_REGION=auto
STORAGE_S3_ACCESS_KEY_ID=replace_me_from_r2_api_token
STORAGE_S3_SECRET_ACCESS_KEY=replace_me_from_r2_api_token

# ---- Clean start: no demo/sample records or workflows in new workspaces ----
IS_WORKSPACE_DEMO_DATA_ENABLED=false

# ============================================================================
# WORKER service: same variables as above, PLUS these two so only the server
# runs migrations/cron (the worker must not):
#   DISABLE_DB_MIGRATIONS=true
#   DISABLE_CRON_JOBS_REGISTRATION=true
# ============================================================================
