COMPOSE_PROJECT_NAME=revenuestorm
# TWENTY_VERSION=replace_me_with_the_latest_upstream_twenty_version

TAG=latest

#PG_DATABASE_USER=postgres
#PG_DATABASE_PASSWORD=replace_me_with_a_strong_password_without_special_characters
#PG_DATABASE_HOST=db
#PG_DATABASE_PORT=5432
#REDIS_URL=redis://redis:6379

TWENTY_PORT=3000
SERVER_URL=http://localhost:${TWENTY_PORT}

# Use openssl rand -base64 32 for each secret
# ENCRYPTION_KEY=replace_me_with_a_random_string
# FALLBACK_ENCRYPTION_KEY= # set to the previous ENCRYPTION_KEY during a rotation
# APP_SECRET= # legacy: only required for instances that pre-date ENCRYPTION_KEY

STORAGE_TYPE=local

# STORAGE_S3_REGION=eu-west3
# STORAGE_S3_NAME=my-bucket
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# OAuth
# AUTH_MICROSOFT_ENABLED=False
# AUTH_MICROSOFT_CLIENT_ID=replace_me_with_client_id
# AUTH_MICROSOFT_CLIENT_SECRET=replace_me_with_client_secret
# AUTH_MICROSOFT_CALLBACK_URL=replace_me_with_callback_url
# AUTH_MICROSOFT_APIS_CALLBACK_URL=replace_me_with_api_callback_url
