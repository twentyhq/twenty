{
  "name": "twenty-docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/twenty-docs",
  "projectType": "application",
  "tags": ["scope:docs"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "mintlify dev"
      }
    },
    "validate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "mintlify validate"
      }
    },
    "lint": {},
    "fmt": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx oxfmt --check ."
      },
      "configurations": {
        "ci": {},
        "fix": {
          "command": "npx oxfmt ."
        }
      }
    }
  }
}
