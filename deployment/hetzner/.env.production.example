# ========================================
# Twenty CRM - Production Environment Configuration
# ========================================
# Copy this file to .env.production and fill in your values

# ========================================
# REQUIRED: Domain & URLs
# ========================================
# Your domain name (without https://)
DOMAIN=your-domain.com

# Full URL where your instance will be accessible
SERVER_URL=https://your-domain.com

# Frontend URL (usually same as SERVER_URL)
FRONTEND_URL=https://your-domain.com

# ========================================
# REQUIRED: Security
# ========================================
# Generate with: openssl rand -hex 32
APP_SECRET=CHANGEME_generate_with_openssl_rand_hex_32

# Token expiration times
ACCESS_TOKEN_EXPIRES_IN=30m
LOGIN_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=90d

# ========================================
# REQUIRED: Database
# ========================================
PG_DATABASE_USER=twenty
# Generate strong password: openssl rand -base64 32
PG_DATABASE_PASSWORD=CHANGEME_generate_strong_password

# ========================================
# REQUIRED: Docker Image
# ========================================
# Which version to deploy (latest, v0.x.x, or commit hash)
TAG=latest

# ========================================
# Features
# ========================================
# Pre-fill sign-in form for testing (disable in production)
SIGN_IN_PREFILLED=false

# Allow multiple workspaces per instance
IS_MULTIWORKSPACE_ENABLED=false

# ========================================
# Storage Configuration
# ========================================
# Storage type: 'local' or 's3'
STORAGE_TYPE=local

# For local storage (default)
STORAGE_LOCAL_PATH=.local-storage

# For S3-compatible storage (Cloudflare R2, AWS S3, MinIO, etc.)
# Uncomment and configure if using S3:
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=auto
# STORAGE_S3_NAME=your-bucket-name
# STORAGE_S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# STORAGE_S3_ACCESS_KEY_ID=your-access-key
# STORAGE_S3_SECRET_ACCESS_KEY=your-secret-key

# ========================================
# Email Configuration (Recommended)
# ========================================
# Email driver: 'logger', 'smtp'
# Use 'logger' for development (emails logged to console)
# Use 'smtp' for production
EMAIL_DRIVER=smtp

EMAIL_FROM_ADDRESS=noreply@your-domain.com
EMAIL_FROM_NAME=Twenty CRM
EMAIL_SYSTEM_ADDRESS=system@your-domain.com

# SMTP Settings (for EMAIL_DRIVER=smtp)
# Example providers:
# - SendGrid: smtp.sendgrid.net:587 (user: apikey, password: your-api-key)
# - AWS SES: email-smtp.us-east-1.amazonaws.com:587
# - Gmail: smtp.gmail.com:587 (requires app password)
# - Mailgun: smtp.mailgun.org:587
EMAIL_SMTP_HOST=smtp.sendgrid.net
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=apikey
EMAIL_SMTP_PASSWORD=your-sendgrid-api-key

# ========================================
# OAuth Authentication (Optional)
# ========================================
# Google OAuth
AUTH_GOOGLE_ENABLED=false
# AUTH_GOOGLE_CLIENT_ID=your-google-client-id
# AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
# AUTH_GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/redirect
# AUTH_GOOGLE_APIS_CALLBACK_URL=https://your-domain.com/auth/google-apis/get-access-token

# Microsoft OAuth
AUTH_MICROSOFT_ENABLED=false
# AUTH_MICROSOFT_CLIENT_ID=your-microsoft-client-id
# AUTH_MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# AUTH_MICROSOFT_CALLBACK_URL=https://your-domain.com/auth/microsoft/redirect
# AUTH_MICROSOFT_APIS_CALLBACK_URL=https://your-domain.com/auth/microsoft-apis/get-access-token

# ========================================
# Calendar & Messaging Integration (Optional)
# ========================================
# Enable Google Calendar sync
CALENDAR_PROVIDER_GOOGLE_ENABLED=false

# Enable Gmail integration
MESSAGING_PROVIDER_GMAIL_ENABLED=false

# Enable Microsoft Calendar sync
CALENDAR_PROVIDER_MICROSOFT_ENABLED=false

# Enable Microsoft Email integration
MESSAGING_PROVIDER_MICROSOFT_ENABLED=false

# ========================================
# Logging & Monitoring (Optional)
# ========================================
# Log levels: error,warn,log,debug,verbose
LOG_LEVELS=error,warn

# Logger driver: console, winston
LOGGER_DRIVER=console

# Sentry for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=production

# ========================================
# Advanced Configuration (Optional)
# ========================================
# Database migrations
DISABLE_DB_MIGRATIONS=false

# Cron job registration
DISABLE_CRON_JOBS_REGISTRATION=false

# PostgreSQL SSL (if your database requires it)
# PG_SSL_ALLOW_SELF_SIGNED=false

# Rate limiting
# API_RATE_LIMITING_TTL=60
# API_RATE_LIMITING_LIMIT=100

# Maximum records affected by a single mutation
# MUTATION_MAXIMUM_AFFECTED_RECORDS=100

# ========================================
# Cloudflare (Optional)
# ========================================
# For custom domain DNS management
# CLOUDFLARE_API_KEY=your-cloudflare-api-key
# CLOUDFLARE_ZONE_ID=your-zone-id
# CLOUDFLARE_WEBHOOK_SECRET=your-webhook-secret

# ========================================
# Analytics (Optional)
# ========================================
# Enable ClickHouse analytics
# ANALYTICS_ENABLED=false
# CLICKHOUSE_URL=http://default:password@clickhouse:8123/twenty

# ========================================
# Notes
# ========================================
# 1. Never commit .env.production to version control
# 2. Generate strong passwords and secrets
# 3. Keep this file secure and backed up
# 4. Update SERVER_URL and FRONTEND_URL to match your domain
# 5. Configure email for password resets to work
# 6. Use S3-compatible storage for better scalability
