{"parentUuid":"d94dc7a9-c843-4790-a737-52104cab3afb","isSidechain":false,"userType":"external","cwd":"/Users/prince/work/twenty","sessionId":"5d4d18e2-7c66-48da-8d20-a34af99f7b25","version":"2.1.71","gitBranch":"main","slug":"logical-squishing-sprout","type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JdEbDczkKX8Bs2zc6yWDxn","type":"tool_result","content":"     1→name: 'Website Preview Dispatch'\n     2→\n     3→permissions:\n     4→  contents: read\n     5→\n     6→on:\n     7→  pull_request:\n     8→    types: [opened, synchronize, reopened, closed, labeled]\n     9→    paths:\n    10→      - packages/twenty-website/**\n    11→      - .github/workflows/website-preview-dispatch.yaml\n    12→\n    13→concurrency:\n    14→  # Keyed on PR number so independent PRs don't cancel each other. `github.ref`\n    15→  # would resolve to the base branch under pull_request and collide.\n    16→  group: ${{ github.workflow }}-${{ github.event.pull_request.number }}\n    17→  cancel-in-progress: true\n    18→\n    19→jobs:\n    20→  trigger-build:\n    21→    # Same fork PRs from outside the org don't have `secrets.*` so the dispatch\n    22→    # call would fail anyway — skip explicitly to avoid noise.\n    23→    if: |\n    24→      github.event.pull_request.head.repo.full_name == github.repository &&\n    25→      github.event.action != 'closed' && (\n    26→        (github.event.action == 'labeled' && github.event.label.name == 'preview-website') ||\n    27→        (\n    28→          (\n    29→            github.event.pull_request.author_association == 'MEMBER' ||\n    30→            github.event.pull_request.author_association == 'OWNER' ||\n    31→            github.event.pull_request.author_association == 'COLLABORATOR'\n    32→          ) && contains(fromJSON('[\"opened\",\"synchronize\",\"reopened\"]'), github.event.action)\n    33→        )\n    34→      )\n    35→    runs-on: ubuntu-latest\n    36→    timeou