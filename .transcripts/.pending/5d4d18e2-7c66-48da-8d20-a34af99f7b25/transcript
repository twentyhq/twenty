ead_sha=$EVENT_SHA\" >> \"$GITHUB_OUTPUT\"\n    42→          fi\n    43→\n    44→      - name: Post pending status\n    45→        env:\n    46→          GH_TOKEN: ${{ github.token }}\n    47→          REPO: ${{ github.repository }}\n    48→          HEAD_SHA: ${{ steps.sha.outputs.head_sha }}\n    49→        run: |\n    50→          gh api \"repos/$REPO/statuses/$HEAD_SHA\" \\\n    51→            -f state=pending \\\n    52→            -f context=app-prod-parity-e2e \\\n    53→            -f description=\"Dispatching prod-parity e2e to ci-privileged\"\n    54→\n    55→      - name: Mint ci-privileged dispatch token\n    56→        id: app-token\n    57→        uses: actions/create-github-app-token@bcd2ba49218906704ab6c1aa796996da409d3eb1 # v3.2.0\n    58→        with:\n    59→          client-id: ${{ vars.TWENTY_WORKFLOW_DISPATCHER_CLIENT_ID }}\n    60→          private-key: ${{ secrets.TWENTY_WORKFLOW_DISPATCHER_PRIVATE_KEY }}\n    61→          owner: twentyhq\n    62→          repositories: ci-privileged\n    63→          permission-actions: write\n    64→\n    65→      - name: Dispatch to ci-privileged\n    66→        env:\n    67→          GH_TOKEN: ${{ steps.app-token.outputs.token }}\n    68→          HEAD_SHA: ${{ steps.sha.outputs.head_sha }}\n    69→        run: |\n    70→          gh workflow run app-prod-parity-e2e.yaml \\\n    71→            --repo twentyhq/ci-privileged \\\n    72→            --ref main \\\n    73→            -f head_sha=\"$HEAD_SHA\"\n    74→\n    75→      - name: Post dispatch-failed status\n    76→        if: failure()\n    77→        env:\n    78→          GH_TOKEN: ${{ github.token }}\n    79→          REPO: ${{ github.repository }}\n    80→          HEAD_SHA: ${{ steps.sha.outputs.head_sha }}\n    81→        run: |\n    82→          gh api \"repos/$REPO/statuses/$HEAD_SHA\" \\\n    83→            -f state=failure \\\n    84→            -f context=app-prod-parity-e2e \\\n    85→            -f description=\"Failed to dispatch prod-