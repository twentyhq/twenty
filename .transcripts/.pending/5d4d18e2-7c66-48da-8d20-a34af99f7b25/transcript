\n    45→          git fetch origin i18n || true\n    46→          git checkout -B i18n origin/i18n || git checkout -b i18n\n    47→\n    48→      - name: Install dependencies\n    49→        uses: ./.github/actions/yarn-install\n    50→\n    51→      - name: Build twenty-shared\n    52→        run: npx nx build twenty-shared\n    53→\n    54→      # Strict mode fails if there are missing translations.\n    55→      - name: Compile translations\n    56→        id: compile_translations_strict\n    57→        run: |\n    58→          npx nx run twenty-server:lingui:compile --strict\n    59→          npx nx run twenty-emails:lingui:compile --strict\n    60→          npx nx run twenty-front:lingui:compile --strict\n    61→        continue-on-error: true\n    62→\n    63→      - name: Stash any changes before pulling translations\n    64→        run: |\n    65→          git config --global user.name 'github-actions'\n    66→          git config --global user.email 'github-actions@twenty.com'\n    67→          git add .\n    68→          git stash\n    69→\n    70→      - name: Pull translations from Crowdin\n    71→        if: inputs.force_pull || steps.compile_translations_strict.outcome == 'failure'\n    72→        uses: crowdin/github-action@8868a33591d21088edfc398968173a3b98d51706 # v2\n    73→        with:\n    74→          upload_sources: false\n    75→          upload_translations: false\n    76→          download_translations: true\n    77→          export_only_approved: false\n    78→          localization_branch_name: i18n\n    79→          base_url: 'https://twenty.api.crowdin.com'\n    80→          auto_approve_imported: false\n    81→          import_eq_suggestions: false\n    82→          download_sources: false\n    83→          push_sources: false\n    84→          skip_untranslated_strings: false\n    85→          skip_untranslated_files: false\n    86→          push_translations: false\n    87→          create_pull_request: false\n    88→          skip_ref_checkout: true\n    89→          dryrun_action: false\n    90→          config: '.github/crowdin-app.yml'\n    91→        env:\n    92→          GITHUB_TOKEN: ${{ github.token }}\n    93→          # App translations project\n    94→          CROWDIN_PROJECT_ID: '1'\n    95→          CROWDIN_PERSONAL_TOKEN: ${{ secrets.CROWDIN_PERSONAL_TOKEN }}\n    96→\n    97→      # As the files are extracted from a Docker container, they belong to root:root\n    98→      # We need to fix this before the next steps\n    99→      - name: Fix file permissions\n   100→        run: sudo chown -R runner:docker .\n   101→\n   102→      # Fix encoding issues (escaped Unicode like \\u62db -> 招) and push fixes back to Crowdin\n   103→      - name: Fix translation encoding and sync to Crowdin\n   104→        run: npx ts-node packages/twenty-utils/fix-crowdin-translations.ts\n   105→        env:\n   106→          CROWDIN_PERSONAL_TOKEN: ${{ secrets.CROWDIN_PERSONAL_TOKEN }}\n   107→\n   108→      - name: Compile translations\n   109→        id: compile_translations\n   110→        # Because we have set English as a fallback locale, this condition does not work anymore\n   111→        # if: inputs.force_pull || steps.compile_translations_strict.outcome == 'failure'\n   112→        run: |\n   113→          npx nx run twenty-server:lingui:compile\n   114→          npx nx run twenty-emails:lingui:compile\n   115→          npx nx run twenty-front:lingui:compile\n   116→          git status\n   117→          git add .\n   118→          if ! git diff --staged --quiet --exit-code; then\n   119→            git commit -m \"chore: compile translations\"\n   120→            echo \"changes_detected=true\" >> $GITHUB_OUTPUT\n   121→          else\n   122→            echo \"changes_detected=false\" >> $GITHUB_OUTPUT\n   123→          fi\n   124→\n   125→      - name: Push changes\n   126→        if: steps.compile_translations.outputs.changes_detected == 'true'\n   127→        run: git push origin HEAD: