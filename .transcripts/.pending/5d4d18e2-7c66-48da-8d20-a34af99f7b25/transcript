bsite i18n branch\n    44→        run: |\n    45→          git fetch origin i18n-website || true\n    46→          git checkout -B i18n-website origin/i18n-website || git checkout -b i18n-website\n    47→\n    48→      - name: Install dependencies\n    49→        uses: ./.github/actions/yarn-install\n    50→\n    51→      - name: Build twenty-shared\n    52→        run: npx nx build twenty-shared\n    53→\n    54→      # Strict mode fails if there are missing website translations.\n    55→      - name: Compile website translations\n    56→        id: compile_translations_strict\n    57→        run: npx nx run twenty-website:lingui:compile --strict\n    58→        continue-on-error: true\n    59→\n    60→      - name: Stash any changes before pulling translations\n    61→        run: |\n    62→          git config --global user.name 'github-actions'\n    63→          git config --global user.email 'github-actions@twenty.com'\n    64→          git add .\n    65→          git stash\n    66→\n    67→      - name: Pull website translations from Crowdin\n    68→        if: inputs.force_pull || steps.compile_translations_strict.outcome == 'failure'\n    69→        uses: crowdin/github-action@8868a33591d21088edfc398968173a3b98d51706 # v2\n    70→        with:\n    71→          upload_sources: false\n    72→          upload_translations: false\n    73→          download_translations: true\n    74→          source: 'packages/twenty-website/src/locales/en.po'\n    75→          translation: 'packages/twenty-website/src/locales/%locale%.po'\n    76→          export_only_approved: false\n    77→          localization_branch_name: i18n-website\n    78→          base_url: 'https://twenty.api.crowdin.com'\n    79→          auto_approve_imported: false\n    80→          import_eq_suggestions: false\n    81→          download_sources: false\n    82→          push_sources: false\n    83→          skip_untranslated_strings: false\n    84→          skip_untranslated_files: false\n    85→          push_translations: false\n    86→          create_pull_request: false\n    87→          skip_ref_checkout: true\n    88→          dryrun_action: false\n    89→          config: '.github/crowdin-website.yml'\n    90→        env:\n    91→          GITHUB_TOKEN: ${{ github.token }}\n    92→          # Website translations project\n    93→          CROWDIN_PROJECT_ID: '4'\n    94→          CROWDIN_PERSONAL_TOKEN: ${{ secrets.CROWDIN_PERSONAL_TOKEN }}\n    95→\n    96→      # As the files are extracted from a Docker container, they belong to root:root.\n    97→      # We need to fix this before the next steps.\n    98→      - name: Fix file permissions\n    99→        run: sudo chown -R runner:docker .\n   100→\n   101→      - name: Compile website translations\n   102→        id: compile_translations\n   103→        run: |\n   104→          npx nx run twenty-website:lingui:compile\n   105→          git status\n   106→          git add packages/twenty-website/src/locales\n   107→          if ! git diff --staged --quiet --exit-code; then\n   108→            git commit -m \"chore: compile website translations\"\n   109→            echo \"changes_detected=true\" >> $GITHUB_OUTPUT\n   110→          else\n   111→            echo \"changes_detected=false\" >> $GITHUB_OUTPUT\n   112→          fi\n   113→\n   114→      - name: Push changes\n   115→        if: steps.compile_translations.outputs.changes_detected == 'true'\n   116→        run: git push origin HEAD:i18n-website\n   117→\n   118→      - name: Create pull request\n   119→        if: steps.compile_translations.outputs.changes_detected == 'true'\n   120→        run: |\n   121→          if git diff --name-only origin/main..HEAD | grep -q .; then\n   122→            gh pr create -B main -H i18n-website --title 'i18n - website translations' --body 'Created by Github action' || true\n   123→          else\n   124→            echo \"No file differences between branches, skipping PR creation\"\n   125→          fi\n   126→        env:\n   127→          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}\n   128→\n   129→      - name: Mint twenty-infra dispatch token\n   130→        id: app-token\n   131→        if: steps.compile_translations.outputs.changes_detected == 'true'\n   132→        uses: actions/create-github-app-token@bcd2ba49218906704ab6c1aa796996da409d3eb1 # v3.2.0\n   133→        with:\n   134→          client-id: ${{ vars.TWENTY_WORKFLOW_DISPATCHER_CLIENT_ID }}\n   135→          private-key: ${{ secrets.TWENTY_WORKFLOW_DISPATCHER_PRIVATE_KEY }}\n   136→          owner: twentyhq\n   137→          repositories: twenty-infra\n   138→          permission-actions: write\n   139→\n   140→      - name: Trigger i18n automerge\n   141→        if: steps.compile_translations.outputs.changes_detected == 'true'\n   142→        env:\n   143→          GH_TOKEN: ${{ steps.app-token.outputs.token }}\n   144→        run: |\n   145→          gh workflow run automerge-i18n.yaml --repo twentyhq/twenty-infra --ref main\n   146→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"uuid":"bd689dbb-994e-443e-a6c9-686582934570","timestamp":"2026-07-03T06:44:00.652Z"},"type":"agent_progress","prompt":"","agentId":"a787dfa66fd1eefd1"},"toolUseID":"agent_msg_01GVJYhDtZXcm7smWiee2ZwF","parentToolUseID":"toolu_01WzLHT43XVn9Vdpy5XB3S3k","uuid":"371b1422-3c45-4735-9cb0-d1865cea6bc8","timestamp":"2026-07-03T06:44:00.886Z"}
