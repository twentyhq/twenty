# .env.example
#
# Copy to .env (gitignored) when running setup.sh.
# These values get pasted into Railway via the dashboard or CLI per-service.
# This file is the source of truth for "what variables exist and where do they go."
#
# Legend:
#   [server]   set on twenty-server
#   [worker]   set on twenty-worker
#   [backup]   set on twenty-backup
#   [shared]   set on all three

# ═══════════════════════════════════════════════════════════════════════════
# AUTO-WIRED BY RAILWAY (do not paste — Railway resolves these via references)
# ═══════════════════════════════════════════════════════════════════════════
# In the Railway dashboard, set these as variable references rather than literals:
#
# [server]  PG_DATABASE_URL = ${{Postgres.DATABASE_URL}}
# [server]  REDIS_URL       = ${{Redis.REDIS_URL}}
# [worker]  PG_DATABASE_URL = ${{Postgres.DATABASE_URL}}
# [worker]  REDIS_URL       = ${{Redis.REDIS_URL}}
# [backup]  DATABASE_URL    = ${{Postgres.DATABASE_URL}}

# ═══════════════════════════════════════════════════════════════════════════
# SECRETS — generate once with setup.sh, store in 1Password, paste into Railway
# ═══════════════════════════════════════════════════════════════════════════

# [shared] Twenty's signing key. Used for JWTs, encryption-at-rest of secrets.
# 64 random bytes, base64-encoded. NEVER rotate without a migration plan.
APP_SECRET=

# [backup] Passphrase for AES-256 encryption of off-site dumps.
# 32+ random characters. Store in 1Password under "XO Pure / Twenty backup key".
# If you lose this, your R2 backups are unrecoverable.
BACKUP_ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# TWENTY SERVER + WORKER CONFIG
# ═══════════════════════════════════════════════════════════════════════════

# [shared] Public URL of the CRM. Must match the custom domain on twenty-server.
SERVER_URL=https://crm.xopure.com

# [shared] Tells Twenty its public-facing port. Railway injects $PORT; we map it.
NODE_PORT=3000

# [shared] BullMQ is the only supported queue backend now.
MESSAGE_QUEUE_TYPE=bull-mq

# [shared] CRITICAL: prevents anyone with the URL from registering an account.
# Set to false ONLY temporarily when onboarding new admins, then flip back.
IS_SIGN_UP_DISABLED=true
SIGN_IN_PREFILLED=false

# ═══════════════════════════════════════════════════════════════════════════
# OBJECT STORAGE — Cloudflare R2 (S3-compatible)
# ═══════════════════════════════════════════════════════════════════════════
# Create two R2 buckets in Cloudflare:
#   1. xopure-twenty-uploads   (Twenty's attachments — set lifecycle: never)
#   2. xopure-twenty-backups   (pg_dump archives — set lifecycle: delete after 90d)

# [shared] These are for Twenty's attachment storage
STORAGE_TYPE=s3
STORAGE_S3_REGION=auto
STORAGE_S3_NAME=xopure-twenty-uploads
STORAGE_S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# [backup] These are for the backup cron service. Same R2 account, different bucket.
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=xopure-twenty-backups
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
RETENTION_DAYS=30

# ═══════════════════════════════════════════════════════════════════════════
# EMAIL — uses your existing Resend account
# ═══════════════════════════════════════════════════════════════════════════
# [shared]
EMAIL_FROM_ADDRESS=crm@xopure.com
EMAIL_FROM_NAME=XO Pure CRM
EMAIL_DRIVER=smtp
EMAIL_SMTP_HOST=smtp.resend.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=resend
# Paste your existing Resend API key (the same one Vercel uses)
EMAIL_SMTP_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# OBSERVABILITY (optional but recommended)
# ═══════════════════════════════════════════════════════════════════════════
# [shared] Create a NEW Sentry project for Twenty (separate from xopure.com)
SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════
# WEBHOOK SECRETS (set after Twenty is up — used by Vercel sync layer)
# ═══════════════════════════════════════════════════════════════════════════
# These live in Vercel, not Railway, but documenting here so they're not forgotten.
# TWENTY_API_KEY=          generated in Twenty: Settings → Developers → API Keys
# TWENTY_WEBHOOK_SECRET=   shared secret you set when creating Twenty webhooks
# SUPABASE_WEBHOOK_SECRET= shared secret you set when creating Supabase webhooks

# ═══════════════════════════════════════════════════════════════════════════
# XO PURE SUPABASE → TWENTY READ-ONLY BACKFILL
# ═══════════════════════════════════════════════════════════════════════════
# [worker] Preferred source: read-only Postgres DSN for the crm_readonly role.
# This powers the manual Supabase Backfill Action and must never use
# SUPABASE_SERVICE_ROLE_KEY. Creating the role/grants writes to Supabase; do
# not do that while operating under a no-Supabase-write constraint.
XOPURE_SUPABASE_READONLY_DSN=

# [worker] REST fallback when the dedicated DSN is unavailable. Use the
# Supabase project URL (no /rest/v1 suffix) and a publishable/anon key only.
# Never paste SUPABASE_SERVICE_ROLE_KEY here. The fallback performs GET-only
# reads against API-exposed public tables. crm schema views are not visible
# through PostgREST unless Supabase API schemas are changed.
XOPURE_SUPABASE_READONLY_REST_URL=
XOPURE_SUPABASE_READONLY_REST_KEY=
XOPURE_SUPABASE_READONLY_REST_SCHEMA=public

# ═══════════════════════════════════════════════════════════════════════════
# XO PURE PARTNER API — ENRICHMENT LANE (fulfillment/tracking/ambassador metadata)
# ═══════════════════════════════════════════════════════════════════════════
# [worker] Server-to-server read-only API for shipment status, fulfillment
# exceptions, and ambassador directory enrichment. Complements the Supabase
# sync — does NOT replace it. See docs/partner-api-sync-audit-2026-06-20.md.
XOPURE_API_BASE_URL=https://xopure.com/api/partner/v1
XOPURE_PARTNER_API_KEY=
