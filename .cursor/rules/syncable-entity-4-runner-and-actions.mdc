# Syncable Entity Step 4: Runner & Actions

**Purpose:** Create action handlers that execute migration actions against the database.

**Dependencies:** Requires Steps 1-3 (types, cache/transform, builder/validation)

---

## Overview

This step creates:
1. Create action handler
2. Update action handler
3. Delete action handler
4. Universal-to-flat conversion utilities

**Key Concept:** Actions arrive as **universal** (with universal identifiers), must be **transpiled to flat** (with regular IDs) before execution.

---

## Step 4.1: Create Universal-to-Flat Conversion Utility

**File:** `src/engine/workspace-manager/workspace-migration/workspace-migration-runner/action-handlers/my-entity/services/utils/from-universal-flat-my-entity-to-flat-my-entity.util.ts`

```typescript
import { type AllFlatEntityMaps } from 'src/engine/metadata-modules/flat-entity/types/all-flat-entity-maps.type';
import { type FlatMyEntity } from 'src/engine/metadata-modules/flat-my-entity/types/flat-my-entity.type';
import { type UniversalFlatMyEntity } from 'src/engine/workspace-manager/workspace-migration/universal-flat-entity/types/universal-flat-my-entity.type';
import { resolveUniversalRelationIdentifiersToIds } from 'src/engine/workspace-manager/workspace-migration/universal-flat-entity/utils/resolve-universal-relation-identifiers-to-ids.util';
import { type WorkspaceMigrationActionRunnerArgs } from 'src/engine/workspace-manager/workspace-migration/workspace-migration-runner/types/workspace-migration-action-runner-args.type';

export const fromUniversalFlatMyEntityToFlatMyEntity = ({
  universalFlatMyEntity,
  allFlatEntityMaps,
  context,
}: {
  universalFlatMyEntity: UniversalFlatMyEntity;
  allFlatEntityMaps: AllFlatEntityMaps;
  context: WorkspaceMigrationActionRunnerArgs<any>;
}): FlatMyEntity => {
  // Resolve all universal identifiers to regular IDs
  const {
    parentEntityId,
  } = resolveUniversalRelationIdentifiersToIds({
    metadataName: 'myEntity',
    universalFlatEntity: universalFlatMyEntity,
    allFlatEntityMaps,
  });

  // Build flat entity with regular IDs
  const flatMyEntity: FlatMyEntity = {
    id: universalFlatMyEntity.id,
    name: universalFlatMyEntity.name,
    label: universalFlatMyEntity.label,
    icon: universalFlatMyEntity.icon,
    description: universalFlatMyEntity.description,
    
    // Regular foreign key IDs (resolved from universal identifiers)
    parentEntityId,
    
    // Metadata
    isCustom: universalFlatMyEntity.isCustom,
    workspaceId: context.workspaceId,
    universalIdentifier: universalFlatMyEntity.universalIdentifier,
    applicationId: context.applicationId,
    
    // Timestamps
    createdAt: universalFlatMyEntity.createdAt,
    updatedAt: universalFlatMyEntity.updatedAt,
    deletedAt: universalFlatMyEntity.deletedAt,
    
    // OneToMany aggregators (mapped from universal identifiers to IDs)
    childEntityIds: universalFlatMyEntity.childEntityUniversalIdentifiers,
  };

  return flatMyEntity;
};
```

