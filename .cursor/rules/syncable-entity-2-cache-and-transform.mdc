## Step 2.4: Create Input Transform Utilities

### 2.4a. Create Transform Utility

**File:** `src/engine/metadata-modules/flat-my-entity/utils/from-create-my-entity-input-to-universal-flat-my-entity.util.ts`

```typescript
import {
  isDefined,
  trimAndRemoveDuplicatedWhitespacesFromObjectStringProperties,
} from 'twenty-shared/utils';
import { v4 } from 'uuid';

import { type FlatApplication } from 'src/engine/core-modules/application/types/flat-application.type';
import { type AllFlatEntityMaps } from 'src/engine/metadata-modules/flat-entity/types/all-flat-entity-maps.type';
import { resolveEntityRelationUniversalIdentifiers } from 'src/engine/metadata-modules/flat-entity/utils/resolve-entity-relation-universal-identifiers.util';
import { type CreateMyEntityInput } from 'src/engine/metadata-modules/my-entity/dtos/inputs/create-my-entity.input';
import { type UniversalFlatMyEntity } from 'src/engine/workspace-manager/workspace-migration/universal-flat-entity/types/universal-flat-my-entity.type';

export const fromCreateMyEntityInputToUniversalFlatMyEntity = ({
  createMyEntityInput: rawCreateMyEntityInput,
  flatApplication,
  flatObjectMetadataMaps, // Include all flat entity maps needed for relations
}: {
  createMyEntityInput: CreateMyEntityInput;
  flatApplication: FlatApplication;
  flatObjectMetadataMaps?: AllFlatEntityMaps['flatObjectMetadataMaps'];
}): UniversalFlatMyEntity & { id: string } => {
  // Step 1: Sanitize string properties
  const { parentEntityId, ...createMyEntityInput } =
    trimAndRemoveDuplicatedWhitespacesFromObjectStringProperties(
      rawCreateMyEntityInput,
      ['id', 'name', 'label', 'description'], // Properties to sanitize
    );

  // Step 2: Generate IDs and timestamps
  const createdAt = new Date().toISOString();
  const entityId = createMyEntityInput.id ?? v4();
  const universalIdentifier = createMyEntityInput.universalIdentifier ?? v4();

  // Step 3: Resolve foreign keys to universal identifiers
  const {
    parentEntityUniversalIdentifier,
  } = resolveEntityRelationUniversalIdentifiers({
    metadataName: 'myEntity',
    foreignKeyValues: {
      parentEntityId,
    },
    flatEntityMaps: { flatObjectMetadataMaps },
  });

  // Step 4: Build universal flat entity
  const universalFlatMyEntity: UniversalFlatMyEntity & { id: string } = {
    id: entityId,
    name: createMyEntityInput.name,
    label: createMyEntityInput.label,
    icon: createMyEntityInput.icon ?? null,
    description: createMyEntityInput.description ?? null,
    
    // Universal identifiers for relations
    parentEntityUniversalIdentifier,
    
    // Timestamps
    createdAt,
    updatedAt: createdAt,
    deletedAt: null,
    
    // Metadata
    isCustom: true, // User-created entities
    universalIdentifier,
    applicationUniversalIdentifier: flatApplication.universalIdentifier,
    
    // OneToMany aggregators (empty for new entities)
    childEntityUniversalIdentifiers: [],
  };

  return universalFlatMyEntity;
};
```

### 2.4b. Create Update Transform Utility

**File:** `src/engine/metadata-modules/flat-my-entity/utils/from-update-my-entity-input-to-universal-flat-my-entity-updates.util.ts`

```typescript
import { trimAndRemoveDuplicatedWhitespacesFromObjectStringProperties } from 'twenty-shared/utils';

import { type AllFlatEntityMaps } from 'src/engine/metadata-modules/flat-entity/types/all-flat-entity-maps.type';
import { resolveEntityRelationUniversalIdentifiers } from 'src/engine/metadata-modules/flat-entity/utils/resolve-entity-relation-universal-identifiers.util';
import { type UpdateMyEntityInput } from 'src/engine/metadata-modules/my-entity/dtos/inputs/update-my-entity.input';
import { type UniversalFlatMyEntityUpdates } from 'src/engine/workspace-manager/workspace-migration/universal-flat-entity/types/universal-flat-my-entity.type';

export const fromUpdateMyEntityInputToUniversalFlatMyEntityUpdates = ({
  updateMyEntityInput: rawUpdateMyEntityInput,
  flatObjectMetadataMaps,
}: {
  updateMyEntityInput: UpdateMyEntityInput;
  flatObjectMetadataMaps?: AllFlatEntityMaps['flatObjectMetadataMaps'];
}): UniversalFlatMyEntityUpdates => {
  // Extract foreign keys before sanitization
  const { parentEntityId, ...updateMyEntityInput } =
    trimAndRemoveDuplicatedWhitespacesFromObjectStringProperties(
      rawUpdateMyEntityInput,
      ['name', 'label', 'description'],
    );

  // Resolve foreign keys if being updated
  const resolvedRelations =
    parentEntityId !== undefined
      ? resolveEntityRelationUniversalIdentifiers({
          metadataName: 'myEntity',
          foreignKeyValues: { parentEntityId },
          flatEntityMaps: { flatObjectMetadataMaps },
        })
      : {};

  // Build updates (only include properties being updated)
  const updates: UniversalFlatMyEntityUpdates = {
    ...updateMyEntityInput,
    ...resolvedRelations,
  };

  return updates;
};
```

