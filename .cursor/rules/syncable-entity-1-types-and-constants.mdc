## Step 1.5: Define Action Types

**File:** `src/engine/workspace-manager/workspace-migration/workspace-migration-builder/builders/my-entity/types/workspace-migration-my-entity-action.type.ts`

```typescript
import { type UniversalFlatMyEntity } from 'src/engine/workspace-manager/workspace-migration/universal-flat-entity/types/universal-flat-my-entity.type';
import { type FlatMyEntity } from 'src/engine/metadata-modules/flat-my-entity/types/flat-my-entity.type';

// ========== UNIVERSAL ACTIONS (Builder → Runner) ==========

export type UniversalCreateMyEntityAction = {
  type: 'create';
  metadataName: 'myEntity';
  flatEntity: UniversalFlatMyEntity;
};

export type UniversalUpdateMyEntityAction = {
  type: 'update';
  metadataName: 'myEntity';
  universalIdentifier: string;
  update: Partial<
    Pick<
      UniversalFlatMyEntity,
      | 'name'
      | 'label'
      | 'icon'
      | 'description'
      | 'parentEntityUniversalIdentifier' // Universal identifiers for foreign keys
    >
  >;
};

export type UniversalDeleteMyEntityAction = {
  type: 'delete';
  metadataName: 'myEntity';
  universalIdentifier: string;
};

// ========== FLAT ACTIONS (After Transpilation) ==========

export type FlatCreateMyEntityAction = {
  type: 'create';
  metadataName: 'myEntity';
  flatEntity: FlatMyEntity;
};

export type FlatUpdateMyEntityAction = {
  type: 'update';
  metadataName: 'myEntity';
  entityId: string;
  update: Partial<
    Pick<
      FlatMyEntity,
      | 'name'
      | 'label'
      | 'icon'
      | 'description'
      | 'parentEntityId' // Regular IDs for foreign keys
    >
  >;
};

export type FlatDeleteMyEntityAction = {
  type: 'delete';
  metadataName: 'myEntity';
  entityId: string;
};

// ========== LEGACY TYPE ALIASES ==========
// For AllFlatEntityTypesByMetadataName registry

export type CreateMyEntityAction = UniversalCreateMyEntityAction;
export type UpdateMyEntityAction = UniversalUpdateMyEntityAction;
export type DeleteMyEntityAction = UniversalDeleteMyEntityAction;
```

**Key Difference:**
- **Universal**: Uses `*UniversalIdentifier`, identifies by `universalIdentifier`
- **Flat**: Uses `*Id`, identifies by `entityId`

