## Common Test Patterns

### Pattern: Testing Uniqueness
```typescript
let existingEntityId: string;

beforeAll(async () => {
  const { data } = await createMyEntity({
    expectToFail: false,
    input: { name: 'existingEntity', label: 'Existing' },
  });
  existingEntityId = data.createMyEntity.id;
});

it('should fail when name already exists', async () => {
  const { errors } = await createMyEntity({
    expectToFail: true,
    input: { name: 'existingEntity', label: 'Duplicate' },
  });
  
  expectOneNotInternalServerErrorSnapshot({ errors });
});
```

### Pattern: Testing Foreign Key Resolution
```typescript
it('should resolve foreign keys to universal identifiers', async () => {
  const { data: parent } = await createMyEntity({
    expectToFail: false,
    input: { name: 'parent', label: 'Parent' },
  });

  const { data: child } = await createMyEntity({
    expectToFail: false,
    input: {
      name: 'child',
      label: 'Child',
      parentEntityId: parent.createMyEntity.id,
    },
  });

  expect(child.createMyEntity.parentEntityId).toBe(parent.createMyEntity.id);
});
```

### Pattern: Testing Input Sanitization
```typescript
it('should trim whitespace from all string fields', async () => {
  const { data } = await createMyEntity({
    expectToFail: false,
    input: {
      name: '  spacedName  ',
      label: '  Spaced Label  ',
      description: '  Spaced Description  ',
    },
  });

  expect(data.createMyEntity).toMatchObject({
    name: 'spacedName',
    label: 'Spaced Label',
    description: 'Spaced Description',
  });
});
```

