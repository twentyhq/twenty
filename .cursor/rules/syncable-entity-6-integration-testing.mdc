## Step 6.5: Successful Update Tests

**File:** `test/integration/metadata/suites/my-entity/successful-my-entity-update.integration-spec.ts`

```typescript
import { createMyEntity } from 'test/integration/metadata/suites/my-entity/utils/create-my-entity.util';
import { deleteMyEntity } from 'test/integration/metadata/suites/my-entity/utils/delete-my-entity.util';
import { updateMyEntity } from 'test/integration/metadata/suites/my-entity/utils/update-my-entity.util';

describe('My entity update should succeed', () => {
  let entityId: string;

  beforeEach(async () => {
    const { data } = await createMyEntity({
      expectToFail: false,
      input: {
        name: 'entityToUpdate',
        label: 'Entity To Update',
      },
    });
    entityId = data.createMyEntity.id;
  });

  afterEach(async () => {
    if (entityId) {
      await deleteMyEntity({
        expectToFail: false,
        input: { id: entityId },
      });
    }
  });

  it('should update label', async () => {
    const { data } = await updateMyEntity({
      expectToFail: false,
      input: {
        id: entityId,
        label: 'Updated Label',
      },
    });

    expect(data.updateMyEntity).toMatchObject({
      id: entityId,
      name: 'entityToUpdate',
      label: 'Updated Label',
    });
  });

  it('should update multiple fields at once', async () => {
    const { data } = await updateMyEntity({
      expectToFail: false,
      input: {
        id: entityId,
        label: 'New Label',
        description: 'New Description',
      },
    });

    expect(data.updateMyEntity).toMatchObject({
      id: entityId,
      label: 'New Label',
      description: 'New Description',
    });
  });

  it('should preserve unchanged fields', async () => {
    const { data } = await updateMyEntity({
      expectToFail: false,
      input: {
        id: entityId,
        description: 'Added Description',
      },
    });

    expect(data.updateMyEntity).toMatchObject({
      id: entityId,
      name: 'entityToUpdate', // Unchanged
      label: 'Entity To Update', // Unchanged
      description: 'Added Description', // Changed
    });
  });
});
```

